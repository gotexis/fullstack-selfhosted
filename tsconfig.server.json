{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["./src/core/*"]
    }
  },
  "include": ["src/server/**/*.ts", "src/cli/**/*.ts", "src/core/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/web"]
}
